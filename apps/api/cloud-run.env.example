NODE_ENV=production
RENDER_PROVIDER=local

# Legacy Express/Cloud Run render API. The active desktop-worker flow runs through
# apps/web and does not need this file.
# Cloud Run fills PORT automatically. Do not set it manually unless debugging locally.
API_PUBLIC_URL=https://courseforge-remotion-api-xxxxx-uc.a.run.app
EXPRESS_PUBLIC_URL=https://courseforge-remotion-api-xxxxx-uc.a.run.app
REMOTION_ENTRY_POINT=/app/apps/web/src/remotion/index.ts

# Keep origins explicit. Comma-separated, no trailing slash.
ALLOWED_ORIGINS=https://courseforge.netlify.app,https://staging-courseforge.netlify.app

# Supabase secrets must be configured as Cloud Run secrets or encrypted env vars.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-secret-manager-reference

# Render tuning for Cloud Run v1.
REMOTION_RENDER_TIMEOUT_MS=1800000
EXTERNAL_TEMPLATE_RENDER_TIMEOUT_MS=1800000
EXTERNAL_TEMPLATE_PREVIEW_RENDER_TIMEOUT_MS=240000
